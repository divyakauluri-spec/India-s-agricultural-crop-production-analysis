    <dashboard name='Story 1' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' italic='true'>India&apos;s Agricultural Journey: Insights from 25 Years of Data (1997–2021).</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='1585' />
        </style-rule>
      </style>
      <size maxheight='1064' maxwidth='1816' minheight='1064' minwidth='1816' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98496' id='1' param='vert' removable='false' type-v2='layout-flow' w='99118' x='441' y='752'>
            <zone h='3383' id='3' type-v2='title' w='99118' x='441' y='752' />
            <zone h='9492' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99118' x='441' y='4135' />
            <zone h='85621' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99118' x='441' y='13627'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='India&apos;s Agricultural Cultivation: A Data Story&#10;This report explores India&apos;s agricultural sector through interactive visualizations — covering crop production, seasonal variation, regional distribution, and long-term trends from 1997 to 2021, built using Tableau.' captured-sheet='India Agricultural Performance Dashboard.' id='1'>
                    <capturedDeltas>
                      <worksheet name=' State-wise Production Map'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1hh279x0gagh4d1crpekp00drcv6].[Latitude (generated)]' field-type='quantitative' max='4501386.1768624112' min='686144.1029778996' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.1hh279x0gagh4d1crpekp00drcv6].[Longitude (generated)]' field-type='quantitative' max='11131610.516957078' min='6455957.6742082797' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Scenario 1: The Small-Scale Farmer&#10;Rajesh, a small-scale farmer in Uttar Pradesh, wants to maximize yield and income but struggles to choose the right crops each season. Seasonal trends and crop-level insights help him make better farming decisions and reduce risk.' captured-sheet='Farmer&apos;s View — Seasonal &amp; Crop Insights.' id='2'>
                    <capturedDeltas>
                      <worksheet name='Season-wise Production'>
                        <filter class='categorical' column='[federated.1hh279x0gagh4d1crpekp00drcv6].[Action (Crop)]'>
                          <groupfilter function='level-members' level='[Crop]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                      <worksheet name='Trend of Agricultural Yield'>
                        <filter class='categorical' column='[federated.1hh279x0gagh4d1crpekp00drcv6].[Action (Crop)]'>
                          <groupfilter function='level-members' level='[Crop]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Scenario 2: The Government Policy Analyst&#10;Ananya works with the Ministry of Agriculture, designing policies to improve productivity nationwide. By identifying low-yield regions and long-term production trends, she can allocate resources more effectively.' captured-sheet='Policy Analyst&apos;s View' id='3'>
                    <capturedDeltas>
                      <worksheet name=' State-wise Production Map'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1hh279x0gagh4d1crpekp00drcv6].[Latitude (generated)]' field-type='quantitative' max='4361743.0626492361' min='176989.79506521125' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.1hh279x0gagh4d1crpekp00drcv6].[Longitude (generated)]' field-type='quantitative' max='12454239.082556648' min='3029231.2072573183' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Scenario 3: The Agribusiness Investor&#10;Vikram is looking to invest in high-growth agricultural sectors. Analyzing production trends, leading states, and crop performance helps him identify profitable, low-risk investment opportunities.' captured-sheet='Investor View' id='4'>
                    <capturedDeltas>
                      <worksheet name='Cultivated Area by Crop'>
                        <filter class='categorical' column='[federated.1hh279x0gagh4d1crpekp00drcv6].[Action (Production Units)]'>
                          <groupfilter function='level-members' level='[Production_Units]' user:ui-action-filter='[Action6_25233652C730430197DF57EBAA2EE7CD]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                      <worksheet name='Leading States by Production'>
                        <filter class='categorical' column='[federated.1hh279x0gagh4d1crpekp00drcv6].[Action (Production Units)]'>
                          <groupfilter function='level-members' level='[Production_Units]' user:ui-action-filter='[Action6_25233652C730430197DF57EBAA2EE7CD]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                      <worksheet name='Production Distribution by Unit Type'>
                        <selection-collection />
                      </worksheet>
                      <worksheet name='Year-wise Total Production'>
                        <filter class='categorical' column='[federated.1hh279x0gagh4d1crpekp00drcv6].[Action (Production Units)]'>
                          <groupfilter function='level-members' level='[Production_Units]' user:ui-action-filter='[Action6_25233652C730430197DF57EBAA2EE7CD]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='From Data to Decisions&#10;Whether you&apos;re a farmer, policymaker, or investor — 25 years of agricultural data, visualized through Tableau, turns complexity into clarity and insight into action.' captured-sheet='India Agricultural Performance Dashboard.' id='5'>
                    <capturedDeltas>
                      <worksheet name=' State-wise Production Map'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1hh279x0gagh4d1crpekp00drcv6].[Latitude (generated)]' field-type='quantitative' max='5255331.9618510492' min='-2192901.0920030898' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.1hh279x0gagh4d1crpekp00drcv6].[Longitude (generated)]' field-type='quantitative' max='13577480.804185838' min='4449527.3539736979' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                </story-points>
              </flipboard>
